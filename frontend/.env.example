# Frontend environment template (gsheets-backend branch — HYBRID). Copy to `.env`.

# AUTH → Supabase. Only the _System users live here (login/signup/profile).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TOOL DATA → Google Apps Script Web App (server-side Google Sheets). Deploy
# backend/gsheets/Code.gs as a Web app (Execute as: Me / Access: Anyone) with
# the Intern Google account, then paste the /exec URL here. When set, all tool
# data is stored reliably in Sheets server-side (no per-user Google popup).
# Empty = offline/localStorage demo mode.
VITE_API_BASE_URL=

# OPTIONAL — Google Calendar export popup only (not used for tool-data storage).
VITE_GOOGLE_CLIENT_ID=
