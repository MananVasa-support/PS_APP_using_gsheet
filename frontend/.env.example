# Frontend environment template. Copy to `.env`.

# AUTH → Supabase (login / signup / profile). Required for real auth; when
# empty the app runs in offline demo-login mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OPTIONAL — Google Calendar export popup only (a separate feature). Tool data
# is stored in browser localStorage; there is no Google Sheets backend.
VITE_GOOGLE_CLIENT_ID=
