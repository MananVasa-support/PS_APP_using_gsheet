# Frontend environment template. Copy to `.env` and fill in when needed.
# The app runs fully offline today (auth + data are local), so these are OPTIONAL
# until the backend exists.

# Base URL of the future backend API. When set, the per-tool data layer should
# talk to this API and fall back to localStorage when it's empty/unset.
VITE_API_BASE_URL=

# --- Supabase (chosen backend). Fill these in after creating the project:
#     Supabase dashboard → Project Settings → API.
# When both are set, `lib/supabase.js` flips isConfigured=true and the app uses
# the real database + auth instead of the offline/localStorage demo path.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
