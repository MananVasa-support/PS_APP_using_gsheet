# Frontend environment template (gsheets-backend branch — HYBRID).
# Copy to `.env`.

# AUTH → Supabase. Only the `_System` users data lives in Supabase (the
# `app_users` table + RPCs, see backend/supabase-auth/). When both are set,
# login/signup/profile run on Supabase; when absent, the app falls back to
# offline demo login.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TOOL DATA → Google Drive/Sheets. The Google OAuth Client ID (Web app) — the
# same one used for the Calendar export. Drives ALL tool data (Time Auditor,
# Time Finder, Meeting, Power Planner, Reasons Eliminator) stored directly in
# Drive/Sheets. Requires "Google Sheets API" + "Google Drive API" enabled in
# the same Cloud project. When empty, tools fall back to localStorage demo mode.
VITE_GOOGLE_CLIENT_ID=
