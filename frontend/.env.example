# Frontend environment template (gsheets-backend branch). Copy to `.env`.

# The Google Apps Script Web App URL (ends in /exec) — this IS the backend.
# Deploy backend/gsheets/Code.gs as a Web app (Execute as: Me, Access: Anyone)
# and paste the URL here. When set, `lib/gsApi.js` flips isConfigured=true and
# the app uses the Sheets backend; when empty, everything falls back to the
# offline/localStorage demo path.
VITE_API_BASE_URL=

# Google OAuth Client ID for the Calendar export popup (frontend-only flow on
# this branch — the "sign in once" Edge Function is Supabase-only).
VITE_GOOGLE_CLIENT_ID=
