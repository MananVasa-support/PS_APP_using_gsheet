# Frontend environment template. Copy to `.env`.

# AUTH → Supabase (login / signup / profile). When empty → offline demo login.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TOOL DATA → Google Apps Script Web App (server-side Google Sheets, one
# spreadsheet per user). Deploy backend/gsheets/Code.gs as a Web app
# (Execute as: Me / Access: Anyone) and paste the /exec URL here. When empty,
# tool data falls back to browser localStorage (per-browser only).
VITE_API_BASE_URL=

# OPTIONAL — Google Calendar export popup only (a separate feature).
VITE_GOOGLE_CLIENT_ID=
